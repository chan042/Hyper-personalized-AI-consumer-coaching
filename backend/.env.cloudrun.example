DJANGO_SECRET_KEY=replace-with-a-real-secret
DJANGO_DEBUG=False
ALLOWED_HOSTS=.a.run.app,localhost,127.0.0.1

# Web staging frontend origin examples
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.vercel.app,http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=https://your-frontend-domain.vercel.app,http://localhost:3000,http://127.0.0.1:3000
# If you later connect the Capacitor app directly, add regex-based origins like:
# CORS_ALLOWED_ORIGIN_REGEXES=^capacitor://localhost$,^https://localhost$

SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# Cloud SQL public IP or /cloudsql/<INSTANCE_CONNECTION_NAME> socket path
POSTGRES_DB=duduk
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-db-password
POSTGRES_HOST=/cloudsql/your-project:your-region:your-instance
POSTGRES_PORT=5432
POSTGRES_CONN_MAX_AGE=60

RUN_MIGRATIONS=1
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=120
COACHING_TASK_MODE=sync

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

GEMINI_API_KEY=
CLOVA_OCR_URL=
CLOVA_OCR_SECRET=

# Step 2: background jobs
# CELERY_BROKER_URL=redis://...
# CELERY_RESULT_BACKEND=redis://...
